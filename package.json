{
  "name": "@dinovox/mx-swap-widget",
  "version": "0.1.5",
  "description": "DinoVox swap & liquidity widget for MultiversX dApps",
  "keywords": [
    "multiversx",
    "dex",
    "swap",
    "liquidity",
    "react",
    "widget"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dinovox/mx-swap-widget.git"
  },
  "homepage": "https://dinovox.com",
  "type": "module",
  "main": "./dist/mx-swap-widget.umd.js",
  "module": "./dist/mx-swap-widget.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mx-swap-widget.es.js",
      "require": "./dist/mx-swap-widget.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "[ -f dist/mx-swap-widget.es.js ] && echo 'dist already built, skipping' || npm run build",
    "build": "tsc --noEmit && vite build",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "@multiversx/sdk-core": ">=15",
    "@multiversx/sdk-dapp": ">=5",
    "axios": ">=1",
    "bignumber.js": ">=9",
    "lucide-react": ">=0.400",
    "react": ">=18",
    "react-dom": ">=18",
    "react-i18next": ">=15",
    "react-router-dom": ">=6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "18.2.23",
    "@types/react-dom": "18.2.8",
    "@vitejs/plugin-react": "4.4.1",
    "postcss": "^8.5.10",
    "typescript": "5.2.2",
    "vite": "5.4.9",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node-polyfills": "0.22.0"
  }
}
